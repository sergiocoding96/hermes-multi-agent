# CEO profile env template — copy to ~/.hermes/profiles/ceo/.env (chmod 600).
#
# The raw MEMOS_API_KEY is printed once by deploy/scripts/setup-memos-agents.py
# and is NOT recoverable from agents-auth.json (only its bcrypt hash is stored).
# Save it to this file at provision time. Never commit a populated copy.
#
# All values below are the canonical defaults for a fresh Hermes deployment.
# Adjust the cube id lists if extra cubes have been added to the deployment.

# ── MemOS v1 server endpoint ────────────────────────────────────────────────
MEMOS_ENDPOINT=http://localhost:8001

# ── CEO identity ────────────────────────────────────────────────────────────
MEMOS_USER_ID=ceo

# ── CEO API key ─────────────────────────────────────────────────────────────
# Replace with the raw key printed by setup-memos-agents.py.
MEMOS_API_KEY=ak_REPLACE_ME

# ── Cube scope ──────────────────────────────────────────────────────────────
# Writable cubes: where /product/add lands. CEO writes to its own cube only.
MEMOS_WRITABLE_CUBE_IDS=ceo-cube

# Readable cubes: every cube the CEO is shared into. Comma-separated.
# /product/search invokes the v1 CompositeCubeView when more than one is set.
MEMOS_READABLE_CUBE_IDS=ceo-cube,research-cube,email-mkt-cube

# ── Skills source of truth (consumed by memos_list_skills) ─────────────────
# Local clone of https://github.com/sergiocoding96/badass-skills. Keep
# fresh with: git -C "$BADASS_SKILLS_DIR" pull --ff-only origin main
BADASS_SKILLS_DIR=/home/openclaw/Coding/badass-skills

# ── Optional ────────────────────────────────────────────────────────────────
# Override the script's default env-file location if needed:
# CEO_ENV_FILE=~/.hermes/profiles/ceo/.env
