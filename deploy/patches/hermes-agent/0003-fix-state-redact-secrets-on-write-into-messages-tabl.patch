From 9ba9df4cfd802c42061d6843bc99146531e64d6e Mon Sep 17 00:00:00 2001
From: OpenClaw <openclaw@openclaw>
Date: Wed, 29 Apr 2026 14:57:10 +0000
Subject: [PATCH 3/4] fix(state): redact secrets on write into messages table
 (PR-A)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Hooks the redactor module from the previous patch into the two
INSERT INTO messages call sites in hermes_state.py:

  add_message       (single-row append; called per chat turn)
  replace_messages  (bulk reinsert; called by /retry, /undo, /compress)

For each, content (string) and tool_calls (dict/list, recursive)
go through redact() / redact_dict() before SQL parameter binding.
The persisted row never contains the raw secret. The FTS index
populated by the after-INSERT triggers also indexes only the
redacted form.

This is the WRITE half of issue #24's fix path. The READ half
(scrubbing on get_messages_as_conversation as a defense-in-depth
layer for any pre-existing un-redacted rows) ships in the next
patch.

Trade-off: same-turn LLM round-trip still sees the raw secret
on the way to the inference provider — the redactor cannot scrub
what triggered the redaction. Acceptable; the demonstrated
failure mode (T2 from the v1 smoke test) was a CROSS-TURN leak
where the agent quoted a secret from prior message history. The
write-path redactor closes that off prospectively.

Closes hermes-multi-agent#24 PR-A.
---
 hermes_state.py | 22 +++++++++++++++++++++-
 1 file changed, 21 insertions(+), 1 deletion(-)

diff --git a/hermes_state.py b/hermes_state.py
index e2ca596..75e41ac 100644
--- a/hermes_state.py
+++ b/hermes_state.py
@@ -25,6 +25,7 @@ from pathlib import Path
 
 from agent.memory_manager import sanitize_context
 from hermes_constants import get_hermes_home
+from hermes_state_redactor import redact, redact_dict
 from typing import Any, Callable, Dict, List, Optional, TypeVar
 
 logger = logging.getLogger(__name__)
@@ -1110,6 +1111,16 @@ class SessionDB:
         Also increments the session's message_count (and tool_call_count
         if role is 'tool' or tool_calls is present).
         """
+        # Redact secrets from caller-supplied content + tool_calls BEFORE
+        # serialization so the persisted row never contains the raw value.
+        # The MemOS-side redactor (PR #6) only catches secrets at the MemOS
+        # storage boundary; hermes-agent has its own message history at
+        # state.db that's outside that scope. See hermes_state_redactor.py.
+        if isinstance(content, str):
+            content = redact(content)
+        if tool_calls is not None:
+            tool_calls = redact_dict(tool_calls)
+
         # Serialize structured fields to JSON before entering the write txn
         reasoning_details_json = (
             json.dumps(reasoning_details)
@@ -1203,6 +1214,15 @@ class SessionDB:
                     msg.get("codex_message_items") if role == "assistant" else None
                 )
 
+                # Redact secrets before persistence (see hermes_state_redactor).
+                # Same rationale as add_message above: state.db is outside
+                # MemOS's redaction scope so the layer is enforced here.
+                msg_content = msg.get("content")
+                if isinstance(msg_content, str):
+                    msg_content = redact(msg_content)
+                if tool_calls is not None:
+                    tool_calls = redact_dict(tool_calls)
+
                 reasoning_details_json = (
                     json.dumps(reasoning_details) if reasoning_details else None
                 )
@@ -1223,7 +1243,7 @@ class SessionDB:
                     (
                         session_id,
                         role,
-                        msg.get("content"),
+                        msg_content,
                         msg.get("tool_call_id"),
                         tool_calls_json,
                         msg.get("tool_name"),
