From 651b196dffd152d911f0db35579f83c0b40a028e Mon Sep 17 00:00:00 2001
From: OpenClaw <openclaw@openclaw>
Date: Wed, 29 Apr 2026 14:57:28 +0000
Subject: [PATCH 4/4] fix(state): redact secrets on context-load reads (PR-B)

Wraps every content + tool_calls field in
get_messages_as_conversation() with the redactor before it gets
returned to the gateway and added to the LLM's prompt context.

This is the higher-leverage half of issue #24's fix because it
stops the recurring CROSS-TURN leak even when state.db rows
contain raw secrets from before PR-A landed. The LLM context
shows [REDACTED:sk-key] instead of the original value, so the
model cannot quote it back from prior history.

Without this, an existing state.db with un-redacted historical
rows would keep leaking secrets across turns until those rows
naturally aged out (potentially weeks). With it, leak stops
immediately even before an operator runs the one-shot scrubber
at deploy/scripts/scrub-hermes-state-secrets.py.

Closes hermes-multi-agent#24 PR-B.
---
 hermes_state.py | 12 ++++++++++--
 1 file changed, 10 insertions(+), 2 deletions(-)

diff --git a/hermes_state.py b/hermes_state.py
index 75e41ac..5e0f3ca 100644
--- a/hermes_state.py
+++ b/hermes_state.py
@@ -1382,6 +1382,13 @@ class SessionDB:
             content = row["content"]
             if row["role"] in {"user", "assistant"} and isinstance(content, str):
                 content = sanitize_context(content).strip()
+            # Redact loaded message content before it enters the LLM
+            # context. PR-A scrubs new writes; this is the defense-in-depth
+            # layer that catches any pre-existing un-redacted rows
+            # (historical data written before the redactor shipped).
+            # See hermes_state_redactor.py and hermes-multi-agent#24 PR-B.
+            if isinstance(content, str):
+                content = redact(content)
             msg = {"role": row["role"], "content": content}
             if row["tool_call_id"]:
                 msg["tool_call_id"] = row["tool_call_id"]
@@ -1389,10 +1396,11 @@ class SessionDB:
                 msg["tool_name"] = row["tool_name"]
             if row["tool_calls"]:
                 try:
-                    msg["tool_calls"] = json.loads(row["tool_calls"])
+                    parsed_tool_calls = json.loads(row["tool_calls"])
                 except (json.JSONDecodeError, TypeError):
                     logger.warning("Failed to deserialize tool_calls in conversation replay, falling back to []")
-                    msg["tool_calls"] = []
+                    parsed_tool_calls = []
+                msg["tool_calls"] = redact_dict(parsed_tool_calls)
             # Restore reasoning fields on assistant messages so providers
             # that replay reasoning (OpenRouter, OpenAI, Nous) receive
             # coherent multi-turn reasoning context.
