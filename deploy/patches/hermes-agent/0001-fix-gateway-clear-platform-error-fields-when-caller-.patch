From 59fe18bdf9e354dc513714c2a0d0cf99d2c385b7 Mon Sep 17 00:00:00 2001
From: OpenClaw <openclaw@openclaw>
Date: Tue, 28 Apr 2026 09:30:57 +0000
Subject: [PATCH] fix(gateway): clear platform error fields when caller passes
 None

write_runtime_status() guarded error_code/error_message writes with
`is not None`, silently dropping explicit None. Intent had been
"preserve unspecified fields", but every caller that touches these
kwargs treats None as "clear":

  _mark_connected     -> error_code=None, error_message=None
  _mark_disconnected  -> error_code=None, error_message=None
  _set_fatal_error    -> error_code=str,  error_message=str

After a transient connect failure followed by a successful reconnect,
gateway_state.json showed state="connected" alongside the stale
error_code/error_message from the prior attempt, e.g.

  "telegram": {
    "state": "connected",
    "error_code": "telegram_connect_error",
    "error_message": "Telegram startup failed: httpx.ConnectError: ..."
  }

Drop the guards so the caller-supplied value is authoritative;
None serializes to JSON null and overwrites stale state.
---
 gateway/status.py | 12 ++++++++----
 1 file changed, 8 insertions(+), 4 deletions(-)

diff --git a/gateway/status.py b/gateway/status.py
index b0ea693a2..d8d4f2cf0 100644
--- a/gateway/status.py
+++ b/gateway/status.py
@@ -211,10 +211,14 @@ def write_runtime_status(
         platform_payload = payload["platforms"].get(platform, {})
         if platform_state is not None:
             platform_payload["state"] = platform_state
-        if error_code is not None:
-            platform_payload["error_code"] = error_code
-        if error_message is not None:
-            platform_payload["error_message"] = error_message
+        # error_code / error_message: caller-supplied value is authoritative.
+        # Passing None means "clear" — e.g. _mark_connected() resets these
+        # after recovering from a transient connect error so the persisted
+        # state doesn't show stale errors next to a healthy "connected"
+        # state. The previous `is not None` guards turned None into a no-op,
+        # which left stale errors hanging around indefinitely.
+        platform_payload["error_code"] = error_code
+        platform_payload["error_message"] = error_message
         platform_payload["updated_at"] = _utc_now_iso()
         payload["platforms"][platform] = platform_payload
 
-- 
