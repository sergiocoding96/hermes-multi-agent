From 477c198ff9f0d5cd7de6615f5532520b999bfdb3 Mon Sep 17 00:00:00 2001
From: OpenClaw <openclaw@openclaw>
Date: Thu, 30 Apr 2026 18:16:01 +0000
Subject: [PATCH 6/6] fix(state): redact secrets on session-log JSON writes
 (PR-D)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Session JSON dumps at ~/.hermes/profiles/<p>/sessions/session_<id>.json
mirror the per-turn message list to disk for resume / debug / backup.
session_search uses SQLite (already covered by PR-A), but these JSON
files are still attached to bug reports, hermes dump output, and
profile backups, where raw secrets become a recurring exfil risk.

Hook redact_dict() into _save_session_log() right before the entry
dict is built. Walks messages, tools, and the cached system prompt;
non-string fields pass through untouched. Idempotent and cheap on
already-redacted content, so the per-turn rewrite stays O(turn size).

This is defense-in-depth: not a leak path INTO LLM context, but a
leak path OUT of the box via support workflows. Closes the third
of the three persistence channels identified in deploy verification
of PR #26 (state.db ✓, USER.md/MEMORY.md ✓ via PR-C, sessions/*.json
✓ here).
---
 run_agent.py | 16 ++++++++++++++--
 1 file changed, 14 insertions(+), 2 deletions(-)

diff --git a/run_agent.py b/run_agent.py
index 895e68644..85bcc967b 100644
--- a/run_agent.py
+++ b/run_agent.py
@@ -161,6 +161,11 @@ from agent.trajectory import (
 )
 from utils import atomic_json_write, base_url_host_matches, base_url_hostname, env_var_enabled, normalize_proxy_url
 from hermes_cli.config import cfg_get
+# Session JSON dumps are kept on disk under ~/.hermes/profiles/<p>/sessions/.
+# They aren't read back into LLM context, but they ARE attached to bug
+# reports / hermes dump output / backups, so we redact secrets here too.
+# Defense in depth alongside the state.db redaction in hermes_state.py.
+from hermes_state_redactor import redact, redact_dict
 
 
 
@@ -4202,6 +4207,13 @@ class AIAgent:
                 except Exception:
                     pass  # corrupted existing file — allow the overwrite
 
+            # Redact recognised secrets across the whole entry. Walks every
+            # string field (content, tool_calls payloads, system prompt) and
+            # replaces matches with [REDACTED:<class>]. Idempotent for already-
+            # redacted text, so the per-turn rewrite cost stays flat.
+            cleaned = redact_dict(cleaned)
+            cached_system_prompt = redact(self._cached_system_prompt or "") if self._cached_system_prompt else ""
+
             entry = {
                 "session_id": self.session_id,
                 "model": self.model,
@@ -4209,8 +4221,8 @@ class AIAgent:
                 "platform": self.platform,
                 "session_start": self.session_start.isoformat(),
                 "last_updated": datetime.now().isoformat(),
-                "system_prompt": self._cached_system_prompt or "",
-                "tools": self.tools or [],
+                "system_prompt": cached_system_prompt,
+                "tools": redact_dict(self.tools or []),
                 "message_count": len(cleaned),
                 "messages": cleaned,
             }
