From 46996ab1ce1673e0db90dd12fc3ef446c8392178 Mon Sep 17 00:00:00 2001
From: OpenClaw <openclaw@openclaw>
Date: Wed, 29 Apr 2026 14:56:26 +0000
Subject: [PATCH 2/4] feat(state): add secret redactor module for state.db
 hooks

Mirrors the regex set + fast-path behaviour of MemOS PR #6's
memos.core.redactor. Will be wired into hermes_state.add_message,
replace_messages, and get_messages_as_conversation in subsequent
patches so secrets persisted into state.db (and later loaded back
into LLM prompt context) are scrubbed at both layers.

Patterns covered: pem, jwt, bearer, sk-key, aws-key, ssn, email,
phone, card (Luhn-validated). Aggressive on false positives;
zero-tolerance on false negatives. Substring-guarded fast path
keeps benign 1MB redaction under ~50ms.

Card detection runs first (Luhn-validated) so the permissive
phone regex doesn't eat 16-digit PANs and mislabel them.

Idempotent - applying the redactor to already-redacted text is
a no-op.

Closes hermes-multi-agent#24 PR-A prep.
---
 hermes_state_redactor.py | 130 +++++++++++++++++++++++++++++++++++++++
 1 file changed, 130 insertions(+)
 create mode 100644 hermes_state_redactor.py

diff --git a/hermes_state_redactor.py b/hermes_state_redactor.py
new file mode 100644
index 0000000..9d5894f
--- /dev/null
+++ b/hermes_state_redactor.py
@@ -0,0 +1,130 @@
+"""
+Secret redactor for hermes-agent's session state DB.
+
+Mirrors the regex patterns + behaviour of the MemOS server's
+`memos.core.redactor` (PR #6). Lives here so the redaction is applied
+on the hermes-agent side too — i.e. before raw secrets are persisted
+into ``state.db`` and before recorded message history is loaded back
+into LLM prompt context.
+
+Why a separate copy: the MemOS server runs in a different process and
+talks over HTTP to hermes-agent; we cannot share Python imports across
+the boundary. Same regex set, same fast-path, locally enforced.
+
+Patterns covered (in order, first match wins per occurrence):
+  - PEM blocks   ``-----BEGIN ...-----``
+  - JWTs         ``eyJ.<base64>.<base64>``
+  - Bearer tokens (case-insensitive ``Bearer xxx``)
+  - sk- keys     ``sk-...`` (OpenAI-style)
+  - AWS keys     ``AKIA...`` and ``aws_secret_access_key=...``
+  - SSNs         ``###-##-####``
+  - Emails
+  - Card numbers (Luhn-validated 13–19 digits)
+  - Phone numbers (loose international)
+
+Aggressive on false positives is acceptable; false negatives
+(secrets slipping through) are not. ``"the bearer of the message"``
+is intentionally NOT redacted because the regex requires a value
+after ``Bearer ``.
+
+Performance: substring-guarded fast path. For benign 1MB text the
+full pass returns in ~50ms on the reference box.
+"""
+
+from __future__ import annotations
+
+import re
+from typing import Any
+
+# ─── Pattern classes (compiled once at module load) ───
+
+_PATTERNS: list[tuple[str, str, re.Pattern[str]]] = [
+    # (class_name, fast-path substring (must be lowercase since we match against text.lower()), regex)
+    ("pem",     "-----begin",
+     re.compile(r"-----BEGIN [A-Z ]+-----[\s\S]+?-----END [A-Z ]+-----")),
+    ("jwt",     "eyj",
+     re.compile(r"\beyJ[A-Za-z0-9_\-]+\.[A-Za-z0-9_\-]+\.[A-Za-z0-9_\-]+\b")),
+    ("bearer",  "bearer",
+     re.compile(r"\bBearer\s+[A-Za-z0-9._\-+/=]{8,}", re.IGNORECASE)),
+    ("sk-key",  "sk-",
+     re.compile(r"\bsk-[A-Za-z0-9_\-]{16,}")),
+    ("aws-key", "akia",
+     re.compile(r"\bAKIA[0-9A-Z]{16}\b")),
+    ("aws-key", "aws_secret",
+     re.compile(r"aws_secret_access_key\s*=\s*[A-Za-z0-9/+=]{40}", re.IGNORECASE)),
+    ("ssn",     "-",
+     re.compile(r"\b\d{3}-\d{2}-\d{4}\b")),
+    ("email",   "@",
+     re.compile(r"[A-Za-z0-9._%+\-]+@[A-Za-z0-9.\-]+\.[A-Za-z]{2,}")),
+    ("phone",   "",
+     re.compile(r"\+?\d{1,3}[\s\-.]?\(?\d{2,4}\)?[\s\-.]?\d{3,4}[\s\-.]?\d{3,4}")),
+]
+
+# Card numbers handled separately (Luhn validation needed).
+_CARD_RE = re.compile(r"\b\d{13,19}\b")
+
+
+def _luhn_valid(number: str) -> bool:
+    """Standard Luhn checksum."""
+    digits = [int(c) for c in number if c.isdigit()]
+    if len(digits) < 13:
+        return False
+    parity = len(digits) % 2
+    total = 0
+    for i, d in enumerate(digits):
+        if i % 2 == parity:
+            d *= 2
+            if d > 9:
+                d -= 9
+        total += d
+    return total % 10 == 0
+
+
+def redact(text: str) -> str:
+    """
+    Replace every recognised secret in ``text`` with ``[REDACTED:<class>]``.
+    Returns the redacted string. Non-string inputs are returned unchanged.
+
+    Idempotent: redacting an already-redacted string is a no-op.
+    """
+    if not isinstance(text, str) or not text:
+        return text
+
+    out = text
+
+    # Card numbers FIRST (Luhn-validated) — so the permissive phone regex
+    # doesn't eat 16-digit PANs and label them [REDACTED:phone] instead.
+    if any(c.isdigit() for c in out):
+        def _card_sub(m: re.Match[str]) -> str:
+            return "[REDACTED:card]" if _luhn_valid(m.group(0)) else m.group(0)
+        out = _CARD_RE.sub(_card_sub, out)
+
+    lower = out.lower()
+    for cls, hint, pattern in _PATTERNS:
+        if hint and hint not in lower:
+            continue
+        out = pattern.sub(f"[REDACTED:{cls}]", out)
+
+    return out
+
+
+def redact_dict(obj: Any) -> Any:
+    """
+    Recursively walk ``obj`` and apply :func:`redact` to every string
+    field. Non-string fields (ints, bools, None, datetimes, custom
+    objects) pass through untouched.
+
+    Returns a new structure; the input is not mutated.
+    """
+    if isinstance(obj, str):
+        return redact(obj)
+    if isinstance(obj, dict):
+        return {k: redact_dict(v) for k, v in obj.items()}
+    if isinstance(obj, list):
+        return [redact_dict(v) for v in obj]
+    if isinstance(obj, tuple):
+        return tuple(redact_dict(v) for v in obj)
+    return obj
+
+
+__all__ = ["redact", "redact_dict"]
