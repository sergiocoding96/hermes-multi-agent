From 38a8e66d9d5b8c0f64439b181255ab13b81a2dc6 Mon Sep 17 00:00:00 2001
From: OpenClaw <openclaw@openclaw>
Date: Thu, 30 Apr 2026 18:15:49 +0000
Subject: [PATCH 5/6] fix(state): redact secrets on memory tool writes/reads
 (PR-C)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Extends PR #26's state.db redaction to the second persistence channel
the agent uses every session: tools/memory_tool.py, which writes
memories/USER.md and memories/MEMORY.md. Both files are loaded into
the system prompt verbatim at session start, so a raw secret here
round-trips into LLM context indefinitely — exactly the cross-turn
leak observed in deploy verification of PR #26.

Three call sites:

  add(target, content)        — hooks redact() after strip, before
                                 the threat scan and persistence.
  replace(target, old, new)   — same shape; redacts new_content.
  _read_file(path)            — redacts on the way out, so historical
                                 raw entries written before this patch
                                 do not reach the system prompt either.
                                 redact() is idempotent so post-patch
                                 files (already clean) pay no cost.

The read-side mirror is the same defense-in-depth pattern PR-B used
for state.db reads. Pre-existing files are unblocked without waiting
for the operator to run the scrubber.
---
 tools/memory_tool.py | 23 ++++++++++++++++++++++-
 1 file changed, 22 insertions(+), 1 deletion(-)

diff --git a/tools/memory_tool.py b/tools/memory_tool.py
index 0de12a64f..64bdbaada 100644
--- a/tools/memory_tool.py
+++ b/tools/memory_tool.py
@@ -35,6 +35,13 @@ from typing import Dict, Any, List, Optional
 
 from utils import atomic_replace
 
+# Secret redaction. Memory files are loaded into the system prompt at session
+# start, so anything written here is effectively echoed back into LLM context
+# every turn. We mirror the state.db redactor so memories/USER.md and
+# memories/MEMORY.md never persist raw secrets — closes the cross-turn leak
+# path that PR #26's state.db-only patches did not cover.
+from hermes_state_redactor import redact
+
 # fcntl is Unix-only; on Windows use msvcrt for file locking
 msvcrt = None
 try:
@@ -227,6 +234,11 @@ class MemoryStore:
         if not content:
             return {"success": False, "error": "Content cannot be empty."}
 
+        # Redact recognised secrets BEFORE persistence + before the threat scan.
+        # The persisted file is read back into the system prompt next session,
+        # so a raw secret here would round-trip into LLM context.
+        content = redact(content)
+
         # Scan for injection/exfiltration before accepting
         scan_error = _scan_memory_content(content)
         if scan_error:
@@ -275,6 +287,10 @@ class MemoryStore:
         if not new_content:
             return {"success": False, "error": "new_content cannot be empty. Use 'remove' to delete entries."}
 
+        # Redact recognised secrets in the replacement before persistence.
+        # See add() for rationale.
+        new_content = redact(new_content)
+
         # Scan replacement content for injection/exfiltration
         scan_error = _scan_memory_content(new_content)
         if scan_error:
@@ -428,7 +444,12 @@ class MemoryStore:
         # Use ENTRY_DELIMITER for consistency with _write_file. Splitting by "§"
         # alone would incorrectly split entries that contain "§" in their content.
         entries = [e.strip() for e in raw.split(ENTRY_DELIMITER)]
-        return [e for e in entries if e]
+        # Defense-in-depth: redact on read too. Files written before this patch
+        # may contain raw secrets; without this scrub on load, those would still
+        # reach the system prompt until a separate scrubber pass runs. redact()
+        # is idempotent so post-patch files (already redacted on write) are
+        # unaffected.
+        return [redact(e) for e in entries if e]
 
     @staticmethod
     def _write_file(path: Path, entries: List[str]):
