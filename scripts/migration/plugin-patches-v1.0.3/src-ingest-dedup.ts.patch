 import type { SqliteStore } from "../storage/sqlite";
 import type { Logger } from "../types";
 
+// Hermes patch (performance audit 2026-04-23, 1/10 → bounded):
+// Original implementation pulled ALL embeddings via getAllEmbeddings on every
+// dedup call → O(N) scan per ingest, O(N²) write cost overall, P99 12.2s at
+// 6.8k rows under concurrency. Following the pattern already established in
+// storage/vector.ts:vectorSearch, we bound the candidate set to the most
+// recent DEDUP_MAX_SCAN chunks. Tradeoff: a near-duplicate older than the
+// most-recent N chunks won't be caught — acceptable for practical workloads
+// where dedup catches conversational repeats, not archival similarity.
+// Override via env var DEDUP_MAX_SCAN (0 = unbounded, default 10000).
+const DEDUP_MAX_SCAN = (() => {
+  const raw = process.env.DEDUP_MAX_SCAN;
+  if (raw === undefined) return 10_000;
+  const n = Number.parseInt(raw, 10);
+  return Number.isFinite(n) && n >= 0 ? n : 10_000;
+})();
+
+function loadCandidates(store: SqliteStore, ownerFilter?: string[]): Array<{ chunkId: string; vector: number[] }> {
+  return DEDUP_MAX_SCAN > 0
+    ? store.getRecentEmbeddings(DEDUP_MAX_SCAN, ownerFilter)
+    : store.getAllEmbeddings(ownerFilter);
+}
