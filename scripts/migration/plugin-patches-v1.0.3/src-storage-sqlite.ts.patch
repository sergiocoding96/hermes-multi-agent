+  // Hermes patch (observability audit 2026-04-23): WAL + disk probe so the
+  // hub's health endpoint can distinguish healthy from degraded states.
+  getDbStats(): {
+    journalMode: string;
+    pageSize: number;
+    pageCount: number;
+    dbSizeBytes: number;
+    walSizeBytes: number;
+    walPages: number;
+    integrityOk: boolean;
+  } {
+    const journalMode = (this.db.pragma("journal_mode", { simple: true }) as string) ?? "unknown";
+    const pageSize = Number(this.db.pragma("page_size", { simple: true }) ?? 0);
+    const pageCount = Number(this.db.pragma("page_count", { simple: true }) ?? 0);
+    const dbSizeBytes = pageSize * pageCount;
+    let walSizeBytes = 0;
+    try {
+      const dbFile = (this.db.name as unknown as string) || "";
+      if (dbFile) {
+        const walPath = dbFile + "-wal";
+        const fsMod = require("fs") as typeof import("fs");
+        if (fsMod.existsSync(walPath)) walSizeBytes = fsMod.statSync(walPath).size;
+      }
+    } catch { /* best-effort */ }
+    const walPages = pageSize > 0 ? Math.ceil(walSizeBytes / pageSize) : 0;
+    let integrityOk = true;
+    try {
+      const row = this.db.prepare("PRAGMA quick_check(1)").get() as { quick_check?: string } | { ["quick_check(1)"]?: string } | undefined;
+      const v = row ? (Object.values(row)[0] as string | undefined) : undefined;
+      integrityOk = v === "ok";
+    } catch { integrityOk = false; }
+    return { journalMode, pageSize, pageCount, dbSizeBytes, walSizeBytes, walPages, integrityOk };
+  }
